# ╔══════════════════════════════════════════════════════════════╗
# ║  Industrial Knowledge Brain (IKB) v2.3 — Environment         ║
# ║  Copy to .env and fill in production values                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ── General ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
AUTH_ENABLED=false
RBAC_ENABLED=false
DEFAULT_TENANT_ID=default

# ── PostgreSQL / TimescaleDB ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ikb_admin
POSTGRES_PASSWORD=ikb_secret_2024
POSTGRES_DB=ikb_main
DATABASE_URL=postgresql://ikb_admin:ikb_secret_2024@postgres:5432/ikb_main

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ikb_redis_2024
REDIS_URL=redis://:ikb_redis_2024@redis:6379/0

# ── Kafka (KRaft — required for telemetry ingestion) ───────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_PORT=9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_GROUP_ID_PREFIX=ikb

# ── Qdrant (Vector DB) ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_SCORE_THRESHOLD=0.6

# ── Neo4j (Knowledge Graph) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ikb_neo4j_2024
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── Service URLs (inter-service) ─────────────────────────────
KNOWLEDGE_ENGINE_URL=http://knowledge-engine:8001
TELEMETRY_AGGREGATOR_URL=http://telemetry-aggregator:8002

# ── Service Ports (host mapping) ─────────────────────────────
API_GATEWAY_PORT=8000
KNOWLEDGE_ENGINE_PORT=8001
TELEMETRY_PORT=8002
FRONTEND_PORT=3000

# ── LLM / Embeddings (Gemini — REQUIRED for Knowledge Engine) ─
GEMINI_API_KEY=Your_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# ── Auth (JWT / Keycloak — production) ───────────────────────
JWT_SECRET=change-me-to-a-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/factory/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=factory-ai-brain

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── MLflow (optional) ────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5000
MLFLOW_MODEL_NAME=telemetry-lstm-autoencoder
MLFLOW_MODEL_STAGE=Production

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=ikb_grafana_2024
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── Feature flags ────────────────────────────────────────────
ENABLE_SPACY_NER=false
