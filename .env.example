# ╔══════════════════════════════════════════════════════════════╗
# ║  Factory AI Brain — Environment Variables                   ║
# ║  Copy to .env and fill in production values                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ── General ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-random-64-char-string

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ikb_admin
POSTGRES_PASSWORD=ikb_secret_2024
POSTGRES_DB=ikb_main

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ikb_redis_2024

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_GROUP_ID_PREFIX=ikb

# ── Qdrant (Vector DB) ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ── Neo4j (Knowledge Graph) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ikb_neo4j_2024
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── InfluxDB (Time Series) ──────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_PORT=8086
INFLUXDB_USER=ikb_admin
INFLUXDB_PASSWORD=ikb_influx_2024
INFLUXDB_ORG=factory-ai
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=ikb-influx-dev-token-2024

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5000

# ── Observability: Jaeger / OpenTelemetry ────────────────────
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── Prometheus ───────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=ikb_grafana_2024

# ── Service Ports ────────────────────────────────────────────
API_GATEWAY_PORT=8000
RAG_SERVICE_PORT=8001
AGENT_SERVICE_PORT=8002
TELEMETRY_SERVICE_PORT=8003
KG_SERVICE_PORT=8004
INGESTION_SERVICE_PORT=8005
FRONTEND_PORT=3000

# ── LLM / Embedding ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
